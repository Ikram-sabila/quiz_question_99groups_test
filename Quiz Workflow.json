      "id": "f5731037-ea67-42e9-8207-9704b71064bd",
      "name": "Code"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (const item of items) {\n  const quiz = item.json.quiz;\n\n  let message = `📚 Quiz: ${quiz.topic}\\n\\n`;\n\n  quiz.questions.forEach((q, index) => {\n    message += `❓ Question ${index + 1}\\n`;\n    message += `${q.question}\\n\\n`;\n    message += `A. ${q.options.A}\\n`;\n    message += `B. ${q.options.B}\\n`;\n    message += `C. ${q.options.C}\\n`;\n    message += `D. ${q.options.D}\\n\\n`;\n  });\n\n  message += `✍️ Reply with format A, B, C, D, B`;\n\n  item.json.telegram_text = message;\n}\n\nreturn items;"
      },

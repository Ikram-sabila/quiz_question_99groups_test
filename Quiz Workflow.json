    {
      "parameters": {
        "jsCode": "const items = $('AI Agent').all();\n\nfor (const item of items) {\n  const raw = item.json.output;\n\n  const cleaned = raw\n    .replace(/```json/g, '')\n    .replace(/```/g, '')\n    .trim();\n\n  const parsed = JSON.parse(cleaned);\n\n  item.json.quiz = parsed;\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

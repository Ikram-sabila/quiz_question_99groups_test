    {
      "parameters": {
        "jsCode": "const items = $('Telegram Trigger').all();\n\nfor (const item of items) {\n  const raw = item.json.message.text;\n\n  const answers = raw\n    .split(',')\n    .map(a => a.trim().toUpperCase());\n\n  item.json.answers = answers;\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

    {
      "parameters": {
        "jsCode": "let quiz = $('Select rows from a table1').first().json.quiz_data;\n\nif (typeof quiz === 'string') {\n  quiz = JSON.parse(quiz);\n}\n\nconst answers = $input.first().json.answers || [];\n\nlet score = 0;\nlet resultText = `📊 Hasil Quiz\\n\\n`;\n\nquiz.questions.forEach((q, i) => {\n  const userAnswer = answers[i] || \"-\";\n  const correct = q.answer === userAnswer;\n\n  if (correct) score++;\n\n  resultText += `❓ Q${i + 1}\\n`;\n  resultText += `Jawaban kamu: ${userAnswer}\\n`;\n  resultText += `Jawaban benar: ${q.answer}\\n`;\n  resultText += `${correct ? \"✅ Benar\" : \"❌ Salah\"}\\n`;\n  resultText += `💡 ${q.explanation}\\n\\n`;\n});\n\nconst total = quiz.questions.length || 1;\nconst percentage = Math.round((score / total) * 100);\n\nresultText += `🎯 Skor: ${score}/${total} (${percentage}%) \\nApakah anda ingin melakukan quiz kembali`;\n\nreturn [{\n  json: {\n    telegram_text: resultText,\n    score: percentage\n  }\n}];"
      },
